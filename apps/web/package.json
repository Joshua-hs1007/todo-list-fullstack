{
  "name": "@todo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ng serve --host 0.0.0.0 --port 4200",
    "prod": "ng serve --configuration production --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.11",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@angular/router": "21.2.11",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.11",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.18.0",
    "@vitest/coverage-v8": "^4.0.14",
    "typescript": "5.9.3",
    "vitest": "^4.0.14"
  }
}
